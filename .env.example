# ============================================================
# .env.example — Production Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env with real values to the repository.
#
# Notes:
# - VITE_* vars are compiled into the frontend bundle by Vite.
# - All other vars (STRIPE_*, RESEND_*, UPSTASH_*, etc.) are
#   secrets for Supabase Edge Functions only — configure them
#   in Supabase Dashboard → Settings → Edge Functions Secrets.
# ============================================================

# ─── Supabase (required) ────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ─── App ────────────────────────────────────────────────────
VITE_APP_URL=https://yourdomain.com
NODE_ENV=production
# Used by Sentry release tracking (set to your release tag, e.g. 1.2.0)
VITE_APP_VERSION=0.1.0

# ─── Stripe (required for billing) ──────────────────────────
# Frontend (publishable key only — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Edge Functions secrets (never expose to frontend)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Sentry (optional — enables error tracking) ─────────────
VITE_SENTRY_DSN=https://...@sentry.io/...
VITE_SENTRY_ENABLED=true

# ─── Upstash Redis (required for rate limiting) ─────────────
# Edge Functions secrets
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Email — Resend (required for transactional email) ──────
# Edge Functions secret
RESEND_API_KEY=re_...

# ─── Cloudflare Turnstile (required for CAPTCHA on checkout) ─
# Frontend (site key — safe to expose)
VITE_TURNSTILE_SITE_KEY=

# Edge Functions secret
TURNSTILE_SECRET_KEY=

# ─── CORS — Edge Functions allowed origin ────────────────────
# Edge Functions secret — restricts Access-Control-Allow-Origin
# Leave empty to allow all origins (development only)
ALLOWED_ORIGIN=https://yourdomain.com

# ─── Slack — Critical alerts webhook (optional) ──────────────
# Edge Functions secret — for notify-critical-alert function
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Public URL for QR codes in cards/diplomas ──────────────
# Edge Functions secret — must match your production domain
PUBLIC_APP_URL=https://yourdomain.com

# ─── Internal-only security secrets (required for protected internal endpoints) ─
# Edge Functions secrets
INTERNAL_ALERT_SECRET=replace-with-long-random-secret
SEED_TEST_USER_ENABLED=false
SEED_TEST_USER_SECRET=replace-with-long-random-secret

# ─── Cron job authentication ─────────────────────────────────
# Edge Functions secret — REQUIRED for all scheduled cron functions:
#   check-membership-renewal, cleanup-abandoned-memberships, cleanup-expired-tenants,
#   cleanup-pending-payment-memberships, cleanup-tmp-documents, expire-grace-period,
#   expire-memberships, expire-trials, mark-pending-delete, pre-expiration-scheduler,
#   transition-youth-to-adult. Set the same value in your cron scheduler headers.
CRON_SECRET=replace-with-long-random-secret

# ─── Alert notification (notify-critical-alert function) ─────
# Edge Functions secrets — all optional, but at least one channel recommended for prod
ALERT_EMAIL_ENABLED=true
ADMIN_ALERT_EMAIL=ops@yourdomain.com
