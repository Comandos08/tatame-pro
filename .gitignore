# Environment variables (NEVER commit .env with real values)
.env
.env.local
.env.*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Supabase CLI cache (downloaded binaries, ephemeral state)
supabase/.temp/

# Playwright screenshots — keep the directory via .gitkeep, ignore contents
e2e/screenshots/*
!e2e/screenshots/.gitkeep

# Playwright transient artifacts
playwright-report/
test-results/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
